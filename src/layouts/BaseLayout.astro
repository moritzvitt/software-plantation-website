---
import "../styles/global.css";

const {
  title = "Software Plantation GmbH",
  description = "Software Plantation GmbH professionalisiert Softwareentwicklung in KMU mit Substanz, klarer Architektur und einem risikominimierten Weg zum MVP.",
} = Astro.props;

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${basePath}${path.replace(/^\//, "")}`;
const baseSegment = basePath.replace(/\/$/, "");
const rawPath = Astro.url.pathname.replace(/\/index\.html$/, "/");
const currentPath = baseSegment && rawPath.startsWith(baseSegment)
  ? rawPath.slice(baseSegment.length) || "/"
  : rawPath;
const defaultBackground = currentPath === "/" ? "white" : "warm";
const hideHeaderPaths = ["/", "/entwurf-4/", "/nav-test/"];
const showHeader = !hideHeaderPaths.includes(currentPath);
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-bg={defaultBackground} data-width="normal" data-theme="" data-type="classic">
    <div class="page-shell">
      {showHeader && (
        <header class="site-header">
          <button
            class="mobile-nav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="site-nav"
            aria-label="Navigation öffnen"
          >
            <img
              class="brand-logo"
              src={withBase("/assets/Logo/SoftwarePlantation_Logo_farb.svg")}
              alt=""
            />
          </button>
          <a class="brand" href="#top" aria-label="Software Plantation Startseite">
            <img
              class="brand-logo"
              src={withBase("/assets/Logo/SoftwarePlantation_Logo_farb.svg")}
              alt="Software Plantation Logo"
            />
            <span class="brand-text">Software Plantation</span>
          </a>
          <nav class="site-nav" id="site-nav" aria-label="Primär">
            <a href="#kunden">Kunden</a>
            <a href="#herausforderungen">Herausforderungen</a>
            <a href="#substanz">Substanz</a>
            <a href="#mvp">MVP</a>
            <a href="#kontakt">Kontakt</a>
          </nav>
        </header>
      )}

      <main id="top">
        <slot />
      </main>

      <footer class="site-footer">
        <div>
          <p>Software Plantation GmbH</p>
          <p>Software mit Substanz. Zusammenarbeit auf Augenhöhe. In drei Schritten zum MVP.</p>
        </div>
        <nav class="footer-variants" aria-label="Landingpage-Entwürfe">
          <span>Entwürfe vergleichen</span>
          <a href={withBase("/")}>01 Deck</a>
          <a href={withBase("/entwurf-2/")}>02 Kompakt</a>
          <a href={withBase("/entwurf-3/")}>03 Editorial</a>
          <a href={withBase("/entwurf-4/")}>04 Präsentation</a>
          <a href={withBase("/nav-test/")}>Nav Test</a>
        </nav>
        <section class="footer-config" aria-label="Darstellung testen">
          <p>Darstellung testen</p>
          <div>
            <span>Hintergrund</span>
            <button type="button" data-bg-option="warm">Warm</button>
            <button type="button" data-bg-option="white">Weiß</button>
            <button type="button" data-bg-option="green">Grün</button>
            <button type="button" data-bg-option="gray">Grau</button>
          </div>
          <div>
            <span>Breite</span>
            <button type="button" data-width-option="normal">Normal</button>
            <button type="button" data-width-option="wide">Breit</button>
          </div>
          <div>
            <span>Farbschema</span>
            <button type="button" data-theme-option="forest">Wald</button>
            <button type="button" data-theme-option="bright">Weiß</button>
            <button type="button" data-theme-option="sage">Salbei</button>
            <button type="button" data-theme-option="clay">Ton</button>
            <button type="button" data-theme-option="steel">Stahl</button>
          </div>
          <div>
            <span>Schriftpalette</span>
            <button type="button" data-type-option="classic">Klar</button>
            <button type="button" data-type-option="system">Modern</button>
            <button type="button" data-type-option="serif">Beratung</button>
            <button type="button" data-type-option="editorial">Editorial</button>
          </div>
        </section>
      </footer>
    </div>

    <script src={withBase("/script.js")}></script>
  </body>
</html>
